# Required
METACULUS_TOKEN=
OPENROUTER_API_KEY=

# Required for AskNews research.
# Use either ASKNEWS_CLIENT_ID + ASKNEWS_SECRET or ASKNEWS_API_KEY, not both.
ASKNEWS_CLIENT_ID=
ASKNEWS_SECRET=
# ASKNEWS_API_KEY=

# Optional Google SERP research provider
SERPAPI_API_KEY=

# Optional Metaculus API behavior
METACULUS_MAX_CONCURRENT_REQUESTS=1
METACULUS_REQUEST_INTERVAL=3.0
INITIAL_API_GET_RETRY_WAIT_SECONDS=3.0

# Optional AskNews behavior
ASKNEWS_CACHE_MODE=no_cache

# Optional resolution-source crawling
JINA_API_KEY=

# Optional OpenRouter character/token usage tracking
# 0 means track usage but do not stop the run.
# Kept under the old env var name for compatibility; value is now estimated tokens.
OPENROUTER_COST_HARD_LIMIT_USD=0

# Optional Google Workspace export
# Share the Sheet and Drive folder with the service account's client_email.
# Use either raw JSON or base64 JSON for the service account credentials.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_JSON_B64=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_TAB=Money Manager
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_EXPORT_STRICT=false
