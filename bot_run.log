import numpy as np
from scipy import stats

# Known/estimated perfect-score counts (42/42) by year
# Confirmed: 2025=5, 2024=1, 2023=1, 2022=6, 2021~0 (cutoff 24, very hard)
# Earlier known historical values:
# 2019=2, 2018=2, 2017=2, 2016=3, 2015=0? (actually 2015 had cutoff 26),
# 2014=0?, 2013=0?, 2012=0?, 2011=0?, 2010=1, 2009=2 (Makarychev?), 2008=3, 2007=0,
# Using a defensible recent-era reference (2010-2025) approx:
counts = {
 2025:5, 2024:1, 2023:1, 2022:6, 2021:0,
 2020:0, 2019:2, 2018:2, 2017:2, 2016:3,
 2015:0, 2014:0, 2013:0, 2012:0, 2011:0, 2010:1
}
vals = np.array(list(counts.values()))
print("Recent-era (2010-2025) values:", sorted(vals))
print("n =", len(vals))
print("mean =", vals.mean().round(3), " median =", np.median(vals), " std =", vals.std(ddof=1).round(3))
print("max =", vals.max(), " min =", vals.min())

# Quantiles empirically
for q in [5,25,50,75,95]:
    print(f"  {q}th pct: {np.percentile(vals,q):.2f}")

# Fit a Poisson (mean as lambda) and a negative binomial for overdispersion
lam = vals.mean()
print("\nPoisson lambda =", round(lam,3))
print("Poisson P(0..7):", np.round(stats.poisson.pmf(range(8), lam),3))

# Overdispersion: var/mean
print("var/mean =", round(vals.var(ddof=1)/vals.mean(),2), "(>1 => overdispersed)")

